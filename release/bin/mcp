            inputSchema: zEntityMergeRequest,
        }, async (body) => this.handleSdkCall(mergeEntitiesGraphEntitiesMergePost({
            client: this.client,
            body,
        })));
    }
    registerCreateRelation() {
        this.server.registerTool('create_relation', {
            title: 'Create Relation',
